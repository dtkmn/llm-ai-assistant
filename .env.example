# Copy this file to .env for local development.
# Shell environment variables override values from this file.

LLM_BACKEND=ollama
LLM_MODEL=nemotron-3-nano:4b
EMBEDDINGS_MODEL=embeddinggemma
OLLAMA_BASE_URL=http://localhost:11434
MODEL_THINKING=true
# Optional: auto, low, medium, high, or max. GPT-OSS supports low/medium/high only.
# OLLAMA_THINK_LEVEL=auto
FAST_MODE=true

# Optional local web server settings.
WEB_HOST=127.0.0.1
WEB_PORT=7860

# Use this only for deterministic UI smoke tests.
# LLM_BACKEND=mock
